generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum ColumnType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
  FORMULA
}

enum RecordStatus {
  DRAFT
  SYNCED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  googleAccount GoogleAccount?
  sheets        SheetConnection[]
  records       PatientRecord[]
}

model GoogleAccount {
  id                    String   @id @default(cuid())
  userId                String   @unique
  googleEmail           String?
  encryptedRefreshToken String
  encryptedAccessToken  String?
  accessTokenExpiresAt  DateTime?
  scopes                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SheetConnection {
  id              String   @id @default(cuid())
  userId          String
  spreadsheetId   String
  spreadsheetName String?
  sheetName       String   @default("Patients")
  headerRow       Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns SheetColumn[]
  records PatientRecord[]

  @@index([userId])
  @@unique([userId, spreadsheetId, sheetName])
}

model SheetColumn {
  id        String     @id @default(cuid())
  sheetId   String
  key       String
  label     String
  type      ColumnType
  required  Boolean    @default(false)
  options   Json?
  formula   String?
  order     Int
  isDefault Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  sheet SheetConnection @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, key])
  @@index([sheetId])
}

model PatientRecord {
  id              String       @id @default(cuid())
  userId          String
  sheetId         String
  values          Json
  status          RecordStatus @default(DRAFT)
  googleRowNumber Int?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheet SheetConnection @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sheetId])
}
